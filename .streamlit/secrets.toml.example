# Vorlage – KOPIE als ".streamlit/secrets.toml" anlegen (lokal) ODER
# diese Werte im Streamlit-Cloud-Dashboard unter Settings -> Secrets eintragen.
# Die echte secrets.toml NICHT ins Git-Repo committen!

# Dauerhafte Datenbank fürs Deployment (Postgres, z.B. Neon/Supabase).
# Lokal weglassen -> dann wird automatisch SQLite (surfapp.db) verwendet.
DATABASE_URL = "postgresql+psycopg2://USER:PASSWORT@HOST:5432/DBNAME"
